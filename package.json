{
  "name": "upforge-desktop",
  "version": "2.10.2",
  "description": "UpForge Desktop — Automatic Valorant gameplay recording and AI coaching",
  "main": "./out/main/index.js",
  "author": "UpForge",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "patch": "npm version patch --no-git-tag-version",
    "minor": "npm version minor --no-git-tag-version",
    "major": "npm version major --no-git-tag-version",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "type-check": "vue-tsc --noEmit",
    "spatial:sync": "node scripts/generate-spatial-zones.mjs && node scripts/calibrate-manifest-display.mjs --write && node scripts/generate-plant-spots.mjs && node scripts/sync-spatial-to-frontend.mjs",
    "spatial:calibrate": "node scripts/spatial-calibrator.mjs",
    "spatial:plants": "node scripts/generate-plant-spots.mjs",
    "spatial:fetch-cs2-radars": "node scripts/fetch-cs2-radars.mjs",
    "ranks:fetch": "node scripts/fetch-game-rank-assets.mjs",
    "assets:preview": "node scripts/open-asset-preview.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@akiver/boiler-writter": "^1.7.0",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@laihoe/demoparser2": "^0.41.3",
    "axios": "^1.6.0",
    "csgo-protobuf": "^4.1.9",
    "csgo-sharecode": "^5.0.0",
    "demofile": "^2.10.0",
    "discord-rpc": "^4.0.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.0",
    "form-data": "^4.0.0",
    "obs-websocket-js": "^5.0.8",
    "pinia": "^2.1.7",
    "ps-list": "^8.1.1",
    "unbzip2-stream": "^1.4.3",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@rushstack/eslint-patch": "^1.3.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/discord-rpc": "^4.0.10",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/eslint-config-typescript": "^13.0.0",
    "autoprefixer": "^10.4.17",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^3.1.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.0",
    "husky": "^9.1.7",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.0",
    "vue-tsc": "^2.2.0"
  },
  "build": {
    "appId": "gg.upforge.desktop",
    "productName": "UpForge",
    "asarUnpack": [
      "**/node_modules/@laihoe/demoparser2/**/*.node",
      "**/node_modules/@laihoe/demoparser2-*/**/*.node"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "UpForge-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "resources/icon.png",
      "category": "public.app-category.games"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": false,
      "include": "build/installer.nsh",
      "allowElevation": true
    },
    "publish": {
      "provider": "github",
      "owner": "LRAFam",
      "repo": "upforge-desktop",
      "releaseType": "release"
    },
    "extraResources": [
      {
        "from": "resources/ffmpeg",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/trainer",
        "to": "trainer",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/spatial",
        "to": "spatial",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/@akiver/boiler-writter/dist/bin/win32-x64",
        "to": "boiler-writter/win32-x64",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/@akiver/boiler-writter/dist/bin/darwin-arm64",
        "to": "boiler-writter/darwin-arm64",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/@akiver/boiler-writter/dist/bin/darwin-x64",
        "to": "boiler-writter/darwin-x64",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
